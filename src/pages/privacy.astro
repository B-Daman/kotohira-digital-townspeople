---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="プライバシーポリシー"
  description="琴平デジタル町民のプライバシーポリシーです。"
>
  <section class="bg-primary text-white py-10 sm:py-12 text-center">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h1 class="text-3xl sm:text-4xl font-black">プライバシーポリシー</h1>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 prose prose-sm max-w-none">
      <p class="text-text-light">準備中です。</p>
    </div>
  </section>
</BaseLayout>
