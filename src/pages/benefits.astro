---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/siteConfig";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="特典"
  description="琴平デジタル町民の特典をご紹介。琴平mobi無料、スタンプラリー、クーポン、投票権、イベント情報。"
>
  <!-- ページヘッダー -->
  <section class="bg-primary text-white py-10 sm:py-12 text-center">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h1 class="text-3xl sm:text-4xl font-black mb-4">つかうほど、琴平がもっと好きになる。</h1>
      <p class="text-white/80 mb-10">琴平デジタル町民に登録すると、おトクな特典が使えます。</p>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-4xl sm:text-5xl font-black text-white">2,167</p>
          <p class="text-sm font-bold text-white/70 mt-1">LINE友だち数</p>
        </div>
        <div>
          <p class="text-4xl sm:text-5xl font-black text-white">11<span class="text-xl">+</span></p>
          <p class="text-sm font-bold text-white/70 mt-1">パートナースポット</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4つの体験価値 -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-black text-center mb-12 section-title">4つの<span class="text-primary">体験価値</span></h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="text-3xl mb-4">🤝</div>
          <h3 class="font-bold text-lg text-primary mb-2">つながり</h3>
          <p class="text-text-light text-sm">イベントやプロジェクトで全国の仲間とつながりが生まれる</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="text-3xl mb-4">💪</div>
          <h3 class="font-bold text-lg text-primary mb-2">貢献</h3>
          <p class="text-text-light text-sm">讃岐おでん、竹あかりなどのプロジェクトで琴平の力になれる</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="text-3xl mb-4">🎯</div>
          <h3 class="font-bold text-lg text-primary mb-2">おトク</h3>
          <p class="text-text-light text-sm">琴平mobi無料、クーポン、スタンプラリーなど特典が満載</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 具体的な特典内容 -->
  <section class="py-16 sm:py-20 bg-surface-yellow">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-black text-center mb-12 section-title">デジタル町民<span class="text-primary">5つの特典</span></h2>
      <div class="space-y-4 max-w-3xl mx-auto">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
          <span class="bg-primary rounded-full w-12 h-12 flex items-center justify-center text-white font-black text-sm shrink-0">01</span>
          <div>
            <p class="font-bold">琴平mobi 1回無料</p>
            <p class="text-sm text-text-light">相乗り型移動サービス。琴平町全域＋まんのう町の一部、350ヶ所以上の停留所から利用可能</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
          <span class="bg-primary rounded-full w-12 h-12 flex items-center justify-center text-white font-black text-sm shrink-0">02</span>
          <div>
            <p class="font-bold">穴場を巡るスタンプラリー</p>
            <p class="text-sm text-text-light">観光名所や町民しか知らない穴場をQRコードで巡る。必要数を集めて景品と交換</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
          <span class="bg-primary rounded-full w-12 h-12 flex items-center justify-center text-white font-black text-sm shrink-0">03</span>
          <div>
            <p class="font-bold">各店で使えるクーポン</p>
            <p class="text-sm text-text-light">パートナー店舗で使えるおトクなクーポン。グルメと体験のカテゴリから選べます</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
          <span class="bg-primary rounded-full w-12 h-12 flex items-center justify-center text-white font-black text-sm shrink-0">04</span>
          <div>
            <p class="font-bold">デジタル町民投票への参加権</p>
            <p class="text-sm text-text-light">まちづくりに関する投票に参加できます</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-center gap-5">
          <span class="bg-primary rounded-full w-12 h-12 flex items-center justify-center text-white font-black text-sm shrink-0">05</span>
          <div>
            <p class="font-bold">イベント情報のご紹介</p>
            <p class="text-sm text-text-light">琴平で開催されるイベントや行事の情報をいち早くお届け</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 石松先生と琴平探索 -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-black text-center mb-12 section-title">
        石松先生と<span class="text-primary">琴平探索</span> — まち歩きスタンプラリー
      </h2>
      <p class="text-text-light text-center mb-8 max-w-2xl mx-auto">
        民俗学研究家の石松先生と一緒に、琴平の歴史スポットを巡るウォークラリー。<br />
        QRコードを読み取りながらスタンプを集めましょう。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-3xl mx-auto mb-8">
        <div class="text-center">
          <img
            src={`${base}/images/line-screen-strolling.png`}
            alt="琴平探索 LINE画面"
            class="rounded-2xl shadow-lg mx-auto max-w-full mb-4"
          />
        </div>
        <div class="text-center">
          <img
            src={`${base}/images/line-screen-routes.png`}
            alt="琴平探索 ルート選択画面"
            class="rounded-2xl shadow-lg mx-auto max-w-full mb-4"
          />
        </div>
      </div>
      <div class="max-w-2xl mx-auto space-y-4">
        <h3 class="text-lg font-bold text-center mb-4">2つのルート</h3>
        <div class="bg-surface-alt rounded-xl p-5 flex items-center gap-4">
          <span class="bg-primary rounded-full w-10 h-10 flex items-center justify-center text-white font-black text-sm shrink-0">1</span>
          <div>
            <p class="font-bold">琴平駅ルート（約30分）</p>
            <p class="text-sm text-text-light">琴平駅からの歴史探検ウォークラリー</p>
          </div>
        </div>
        <div class="bg-surface-alt rounded-xl p-5 flex items-center gap-4">
          <span class="bg-primary rounded-full w-10 h-10 flex items-center justify-center text-white font-black text-sm shrink-0">2</span>
          <div>
            <p class="font-bold">琴平海洋博物館ルート（約35分）</p>
            <p class="text-sm text-text-light">琴平海洋博物館からの歴史散歩</p>
          </div>
        </div>
      </div>
      <p class="text-text-light text-center mt-8">公式LINEから「琴平探索を始める」で体験できます。</p>
    </div>
  </section>

  <!-- クーポン一覧 -->
  <section class="py-16 sm:py-20 bg-surface-alt">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-black text-center mb-12 section-title">
        <span class="text-primary">クーポン一覧</span>（公式LINEで利用可能）
      </h2>
      <div class="space-y-4 max-w-3xl mx-auto">
        <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex items-center justify-between gap-4">
          <p class="font-bold">Bagel House KOTOHIRA</p>
          <span class="bg-accent px-4 py-1.5 rounded-full text-sm font-bold text-primary whitespace-nowrap">1会計 50円引き</span>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex items-center justify-between gap-4">
          <p class="font-bold">こんぴらうどん参道店</p>
          <span class="bg-accent px-4 py-1.5 rounded-full text-sm font-bold text-primary whitespace-nowrap">うどん類、セット・定食 10%OFF</span>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex items-center justify-between gap-4">
          <p class="font-bold">にしきや（こんぴらさん表木戸）</p>
          <span class="bg-accent px-4 py-1.5 rounded-full text-sm font-bold text-primary whitespace-nowrap">うどんビアでも 50円引き</span>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex items-center justify-between gap-4">
          <p class="font-bold">琴平パークホテル</p>
          <span class="bg-accent px-4 py-1.5 rounded-full text-sm font-bold text-primary whitespace-nowrap">朝食バイキング 300円引き</span>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex items-center justify-between gap-4">
          <p class="font-bold">こんぴら温泉 琴参閣</p>
          <span class="bg-accent px-4 py-1.5 rounded-full text-sm font-bold text-primary whitespace-nowrap">貸切風呂 1杯プレゼント</span>
        </div>
        <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex items-center justify-between gap-4">
          <p class="font-bold">こんぴら温泉湯元八千代</p>
          <span class="bg-accent px-4 py-1.5 rounded-full text-sm font-bold text-primary whitespace-nowrap">1杯プレゼント</span>
        </div>
      </div>
      <p class="text-text-light text-center mt-8 text-sm">※ クーポンは公式LINEアプリ内でご利用いただけます</p>
    </div>
  </section>

  <!-- 琴平への行き方 -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-black text-center mb-12 section-title">
        琴平への<span class="text-primary">行き方</span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-3xl mx-auto mb-8">
        <div class="space-y-6">
          <div class="bg-surface-alt rounded-xl p-6">
            <div class="text-3xl mb-3">🚐</div>
            <h3 class="font-bold text-lg mb-2">琴平mobi</h3>
            <p class="text-sm text-text-light mb-3">相乗り型移動サービス。琴平町全域+まんのう町の一部。</p>
            <span class="bg-accent px-3 py-1 rounded-full text-sm font-bold text-primary">デジタル町民限定！1回無料コード配布中</span>
            <p class="text-sm text-text-light mt-3">1日1,000円 / 30日5,000円</p>
          </div>
          <div class="bg-surface-alt rounded-xl p-6">
            <div class="text-3xl mb-3">🚌</div>
            <h3 class="font-bold text-lg mb-2">高速バス</h3>
            <p class="text-sm text-text-light mb-3">大阪・神戸→琴平 直行4時間<br />東京・名古屋・福岡→琴平は夜行便で寝ている間に到着</p>
            <span class="bg-accent px-3 py-1 rounded-full text-sm font-bold text-primary">デジタル町民限定 半額キャンペーン中</span>
          </div>
          <div class="bg-surface-alt rounded-xl p-6">
            <div class="text-3xl mb-3">✈️</div>
            <h3 class="font-bold text-lg mb-2">飛行機</h3>
            <p class="text-sm text-text-light">高松空港〜琴平まで約50分<br />JAL、ANA、ジェットスターの直行便あり</p>
          </div>
        </div>
        <div class="flex items-center justify-center">
          <img
            src={`${base}/images/line-screen-tourism.png`}
            alt="琴平観光案内 LINE画面"
            class="rounded-2xl shadow-lg max-w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20 bg-primary text-white text-center">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-black mb-4">登録・利用料ともに無料</h2>
      <p class="text-white/80 mb-8">公式LINEで友だち追加するだけで、すべての特典が使えます。</p>
      <a
        href={siteConfig.lineUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-[#06C755] text-white px-10 py-5 rounded-full text-xl font-bold hover:opacity-90 transition-opacity shadow-xl"
      >
        公式LINEで友だち追加する
      </a>
    </div>
  </section>
</BaseLayout>
